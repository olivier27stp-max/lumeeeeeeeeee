# ── Supabase ────────────────────────────────────────────────────
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── App ─────────────────────────────────────────────────────────
APP_URL="http://localhost:5173"
FRONTEND_URL="http://localhost:5173"
API_PORT=3001

# ── Payments encryption (generate with: openssl rand -base64 32)
PAYMENTS_ENCRYPTION_KEY=""

# ── Stripe (optional) ──────────────────────────────────────────
STRIPE_WEBHOOK_SECRET=""

# ── PayPal (optional) ──────────────────────────────────────────
PAYPAL_WEBHOOK_ID=""
PAYPAL_ENV="sandbox"

# ── Mapbox (optional, for job geocoding) ────────────────────────
# If omitted, the API falls back to OpenStreetMap Nominatim.
MAPBOX_GEOCODING_TOKEN=""

# ── Gemini AI (optional) ───────────────────────────────────────
GEMINI_API_KEY=""

# ── Docker Compose ─────────────────────────────────────────────
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="lume"
POSTGRES_PORT=5432
REDIS_PORT=6379
STUDIO_PORT=3100
FRONTEND_PORT=5173

# ── Supabase ────────────────────────────────────────────────────
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── App ─────────────────────────────────────────────────────────
APP_URL="http://localhost:5173"
FRONTEND_URL="http://localhost:5173"
API_PORT=3001

# ── Payments encryption (generate with: openssl rand -base64 32)
PAYMENTS_ENCRYPTION_KEY=""
# Set this to the OLD key when rotating (allows decrypting legacy secrets)
PAYMENTS_ENCRYPTION_KEY_PREVIOUS=""

# ── PII encryption (emails, phones, addresses at rest)
# Uses its own key; falls back to PAYMENTS_ENCRYPTION_KEY if not set.
# Generate with: openssl rand -base64 32
PII_ENCRYPTION_KEY=""

# ── Stripe (optional) ──────────────────────────────────────────
STRIPE_WEBHOOK_SECRET=""

# ── PayPal (optional) ──────────────────────────────────────────
PAYPAL_WEBHOOK_ID=""
PAYPAL_ENV="sandbox"

# ── Mapbox (optional, for job geocoding) ────────────────────────
# If omitted, the API falls back to OpenStreetMap Nominatim.
MAPBOX_GEOCODING_TOKEN=""

# ── Mapbox public token (required for /field-sales D2D map) ─────
# Frontend-facing: must start with pk.eyJ...  Free tier sufficient.
VITE_MAPBOX_TOKEN=""

# ── Twilio SMS (optional) ─────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ── Google Maps (optional, for address autocomplete) ──────────
VITE_GOOGLE_MAPS_API_KEY=""

# ── Stripe Connect (platform keys) ──────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_CONNECT_WEBHOOK_SECRET=""

# ── Gemini AI (optional) ───────────────────────────────────────
GEMINI_API_KEY=""

# ── Resend Email (optional) ───────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="Lume CRM <onboarding@resend.dev>"

# ── Upstash Redis (optional, for persistent rate limiting) ────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Docker Compose ─────────────────────────────────────────────
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="lume"
POSTGRES_PORT=5432
REDIS_PORT=6379
REDIS_PASSWORD="lumeredis"
STUDIO_PORT=3100
FRONTEND_PORT=5173

# ── Logging ─────────────────────────────────────────────────────
# Log level: debug, info, warn, error (default: info)
LOG_LEVEL="info"

# ── Sentry (error tracking — compliance breach detection) ───────
# Create 2 projects on sentry.io (lume-frontend + lume-backend), paste DSNs here.
# See docs/operations/sentry_setup.md.
SENTRY_DSN=""
VITE_SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE="0.1"
VITE_SENTRY_TRACES_SAMPLE_RATE="0.1"

# ── AI prompt PII redaction ─────────────────────────────────────
# Redact PII before sending prompts to Gemini / remote Ollama.
# Leave as "1" in production. Set to "0" ONLY for debugging.
AI_REDACT_PII="1"

# ── External Agent JWT signing key ──────────────────────────────
# Used by POST /api/agent/connect to issue JWTs for the external
# agent service (see server/routes/agent-auth.ts). Optional in dev
# (an ephemeral random key is generated at startup). REQUIRED in
# production so issued tokens survive server restarts.
# Generate with: openssl rand -base64 48
AGENT_JWT_SECRET=""

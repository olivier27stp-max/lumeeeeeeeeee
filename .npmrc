# Lock to official npm registry — prevents supply chain attacks via
# malicious registry redirection or dependency confusion.
registry=https://registry.npmjs.org/

# Require exact versions in package-lock.json
save-exact=true

# Allow legacy peer dependency resolution
legacy-peer-deps=false

# Audit dependencies on install
audit=true

# Don't allow lifecycle scripts from untrusted packages
ignore-scripts=false

# Engine strictness — fail if node version doesn't match
engine-strict=true
